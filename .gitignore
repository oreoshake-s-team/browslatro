# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (yarn berry, nodeLinker: pnpm — node_modules is generated per
# checkout/worktree by `yarn install`, hardlinked from the global store)
/node_modules
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/blob-report
/playwright/.cache

# production
/build
bundle-stats.html
vite.config.*.timestamp-*

# storybook
/storybook-static
*storybook.log

# worktrees
.claude/worktrees/

# playwright MCP server cache
.playwright-mcp/

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# vercel
.vercel

# env files
.env*

# npm lockfile (this project uses yarn berry, not npm)
package-lock.json
